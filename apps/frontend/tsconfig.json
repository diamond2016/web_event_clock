{
  "compilerOptions": {
    "forceConsistentCasingInFileNames": true,
    "strict": true,
    "types": ["node"],
    "baseUrl": "./",
      "paths": {
      "#/*": ["src/*"], // For existing src files
      "#/shared/*": ["../../packages/shared/*"], // common declarations
      "#/backend/*": ["../backend/src/*"]
    },
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "esModuleInterop": true,
    "skipLibCheck": true,
    "ignoreDeprecations": "6.0",
  },
  "include": [
    "src/**/*.ts",
    "src/**/*.d.ts",
    "src/**/*.vue"
  ],
  "exclude": [
    "node_modules",
    "dist"
  ]
}