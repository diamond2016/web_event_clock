{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "outDir": "./dist",
    "rootDir": "./src",
    "strict": true,
    "declaration": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "baseUrl": "./",
      "paths": {
      "#/*": ["src/*"], // For existing src files
      "#/time-publisher/*": ["../time-publisher/*"], // time publisher standalone class
      "#/shared/*": ["../../packages/shared/*"] // common declarations
    },
    "ignoreDeprecations": "6.0"
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist", "tests/**/*"]
}